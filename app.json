{
  "expo": {
    "name": "Cat The Pet",
    "slug": "cat-the-pet",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.piqim.catthepet",
      "buildNumber": "1"
    },
    "assetBundlePatterns": [
      "src/assets/**/*"
    ],
    "plugins": [
      [
        "expo-notifications",
        {
          "color": "#f2b65a"
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": false
        }
      ]
    ]
  }
}
